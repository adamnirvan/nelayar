# =====================================================================
# Nelayar GIS — Docker deployment environment
#
# Copy to .env.docker and fill in the secrets, then run:
#   docker compose --env-file .env.docker up -d --build
#
# This single file feeds BOTH docker-compose variable substitution
# (db/web service config) AND the container environment (Laravel).
# Because config is cached in the image entrypoint, every value Laravel
# reads via env() at runtime MUST live here as a real env var.
# =====================================================================

APP_NAME="Nelayar"
APP_ENV=production
# Generate once with:  docker run --rm nelayar-gis-app php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
# Public URL of the server (used for absolute links, Sanctum, etc.)
APP_URL=https://nelayar.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# Log to stderr so output shows up in `docker compose logs`.
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# --- Host port nginx is published on ---
HTTP_PORT=80

# --- Database (service name "db") ---
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=nelayar_gis
DB_USERNAME=nelayar
DB_PASSWORD=change-me-strong-password

# --- Sessions / queue / cache ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=redis

# --- Redis (service name "redis") ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# --- Python microservices ---
# Path to the venv baked into the image; resolves correctly for
# OceanService, FishPriceService, and RouteService. Do not change.
PYTHON_PATH=microservice/.venv/bin/python

# --- Copernicus Marine (CMEMS) credentials for ocean:sync-forecast ---
CMEMS_USERNAME=
CMEMS_PASSWORD=

# --- Mail (defaults to log driver) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
