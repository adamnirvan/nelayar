# PHP / JS dependencies (reinstalled in build stages)
vendor
node_modules

# Python virtualenv (rebuilt inside the image)
microservice/.venv
microservice/__pycache__
**/__pycache__

# Build output (regenerated by Vite in the assets stage)
public/build
public/hot
bootstrap/ssr
public/storage

# Caches & logs
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
.phpunit.cache
.phpunit.result.cache

